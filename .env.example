# ============================================
# LUCAS CHATBOT MVP - Variables de entorno
# ============================================
# Copiar este archivo a .env y completar con tus keys reales.
# El archivo .env NO se sube a git (está en .gitignore).

# ---- IA Providers (al menos Anthropic obligatorio) ----
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-pro-latest

# ---- Lead Capture: Email SMTP (opcional, recomendado) ----
# Para Gmail: crear una "contraseña de aplicación" en
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
LEAD_RECIPIENT=tu@email.com

# ---- Lead Capture: Google Sheets (opcional) ----
# Requiere service account JSON en credentials/google-sa.json
GOOGLE_SHEETS_ID=
GOOGLE_SA_PATH=credentials/google-sa.json
GOOGLE_SHEETS_TAB=Leads

# ---- Lead Capture: Webhook n8n / Zapier / Make (opcional) ----
LEAD_WEBHOOK_URL=

# ---- Alertas de agenda (Telegram — recomendado, gratis) ----
# Creá un bot con @BotFather en Telegram, te da el TOKEN.
# Para el CHAT_ID: mandale "/start" al bot desde tu celular, después abrí:
#   https://api.telegram.org/bot<TU_TOKEN>/getUpdates
# buscá "chat":{"id":XXXXXXX} — ese número es tu chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Alertas por webhook adicional (opcional) ----
# Si preferís n8n / Zapier / Make / WhatsApp Business, pegá acá la URL.
# Se llama POST con el evento cuando se reserva una reunión nueva
# Y cuando faltan 15 minutos para una reunión existente.
NOTIFY_WEBHOOK_URL=

# ---- Servidor ----
HOST=127.0.0.1
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ---- Comportamiento del agente ----
TYPING_DELAY_MIN=1.0
TYPING_DELAY_MAX=2.2
INACTIVITY_TIMEOUT=600
